        <ownedOperation xmi:id="cls_GameEngine_op_start" name="start" visibility="public"/>
        <ownedOperation xmi:id="cls_GameEngine_op_main" name="main" visibility="public" isStatic="true"/>
      </packagedElement>

    </packagedElement>

