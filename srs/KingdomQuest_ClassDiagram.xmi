<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1" xmlns:xmi="http://schema.omg.org/spec/XMI/2.1" xmlns:uml="http://schema.omg.org/spec/UML/2.1" xmlns:MagicDraw_18.0="http://www.magicdraw.com/schemas/xmi">

  <!-- ============================================================ -->
  <!-- MODEL: Kingdom Quest Class Diagram                            -->
  <!-- Object-Oriented Programming Section 1                         -->
  <!-- ============================================================ -->
  <uml:Model xmi:id="model_1" name="KingdomQuest">

    <!-- ======================================================== -->
    <!-- PACKAGE: core                                             -->
    <!-- ======================================================== -->
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_core" name="core">

      <!-- ====================================================== -->
      <!-- INTERFACE: CombatMan                                   -->
      <!-- ====================================================== -->
      <packagedElement xmi:type="uml:Interface" xmi:id="ifc_CombatMan" name="CombatMan">
        <ownedComment xmi:id="cmt_CombatMan">
          <body>Contract for all entities that participate in battle. Implemented by both Character and Enemy.</body>
        </ownedComment>
        <ownedAttribute xmi:id="ifc_CombatMan_attr1" name="attack" type="umldt:Integer" visibility="public">
          <body>Calculate and return damage dealt</body>
        </ownedAttribute>
        <ownedOperation xmi:id="ifc_CombatMan_op_attack" name="attack" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Returns damage dealt by this entity</body>
        </ownedOperation>
        <ownedOperation xmi:id="ifc_CombatMan_op_takeDmg" name="takeDmg" visibility="public">
          <body>Reduce health by damage amount</body>
          <ownedParameter xmi:id="ifc_CombatMan_op_takeDmg_p1" name="dmg" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="ifc_CombatMan_op_isAlive" name="isAlive" visibility="public">
          <type xmi:idref="umldt_Boolean"/>
          <body>Check if entity is still alive (health > 0)</body>
        </ownedOperation>
        <ownedOperation xmi:id="ifc_CombatMan_op_getName" name="getName" visibility="public">
          <type xmi:idref="umldt_String"/>
          <body>Return entity name</body>
        </ownedOperation>
        <ownedOperation xmi:id="ifc_CombatMan_op_getHealth" name="getHealth" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Return current health points</body>
        </ownedOperation>
        <ownedOperation xmi:id="ifc_CombatMan_op_getMaxHealth" name="getMaxHealth" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Return maximum health points</body>
        </ownedOperation>
      </packagedElement>

    </packagedElement>

    <!-- ======================================================== -->
    <!-- PACKAGE: model                                            -->
    <!-- ======================================================== -->
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_model" name="model">

      <!-- ====================================================== -->
      <!-- ABSTRACT CLASS: Character                              -->
      <!-- ====================================================== -->
      <packagedElement xmi:type="uml:Class" xmi:id="cls_Character" name="Character" isAbstract="true">
        <ownedComment xmi:id="cmt_Character">
          <body>Abstract base class for all player archetypes. Implements CombatMan interface.
Contains core RPG stats, inventory, and quest book.
Uses constructor overloading with this() chaining.</body>
        </ownedComment>

        <!-- FIELDS -->
        <ownedAttribute xmi:id="cls_Character_f_name" name="name" visibility="private">
          <type href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library#String"/>
          <body>Character's display name</body>
        </ownedAttribute>
        <ownedAttribute xmi:id="cls_Character_f_health" name="health" visibility="private">
          <type href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library#int"/>
          <body>Current health points</body>
        </ownedAttribute>
        <ownedAttribute xmi:id="cls_Character_f_maxHealth" name="maxHealth" visibility="private">
          <type href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library#int"/>
          <body>Maximum health points</body>
        </ownedAttribute>
        <ownedAttribute xmi:id="cls_Character_f_level" name="level" visibility="private">
          <type href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library#int"/>
          <body>Current character level</body>
        </ownedAttribute>
        <ownedAttribute xmi:id="cls_Character_f_exp" name="exp" visibility="private">
          <type href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library#int"/>
          <body>Current experience points</body>
        </ownedAttribute>
        <ownedAttribute xmi:id="cls_Character_f_inventory" name="inventory" visibility="private">
          <type xmi:idref="cls_Inventory"/>
          <body>HAS-A Inventory for item storage</body>
        </ownedAttribute>
        <ownedAttribute xmi:id="cls_Character_f_questBook" name="questBook" visibility="private">
          <type xmi:idref="cls_QuestBook"/>
          <body>HAS-A QuestBook for quest tracking</body>
        </ownedAttribute>

        <!-- CONSTRUCTORS -->
        <ownedOperation xmi:id="cls_Character_ctor1" name="Character" visibility="public">
          <body>Constructor with name only. Chains to Character(name, 100).</body>
          <ownedParameter xmi:id="cls_Character_ctor1_p1" name="name" type="umldt:String"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_ctor2" name="Character" visibility="public">
          <body>Constructor with name and maxHealth. Initializes all fields.</body>
          <ownedParameter xmi:id="cls_Character_ctor2_p1" name="name" type="umldt:String"/>
          <ownedParameter xmi:id="cls_Character_ctor2_p2" name="maxHealth" type="umldt:Integer"/>
        </ownedOperation>

        <!-- METHODS -->
        <ownedOperation xmi:id="cls_Character_op_attack" name="attack" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Calculates base damage + equipped weapon bonus. Calls getBaseAttack() (polymorphic).</body>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getBaseAttack" name="getBaseAttack" visibility="protected" isAbstract="true">
          <type xmi:idref="umldt_Integer"/>
          <body>Abstract method. Each subclass defines its own attack formula.</body>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_gainExperience" name="gainExperience" visibility="public">
          <body>Adds EXP and auto-levels with while loop when crossing thresholds.</body>
          <ownedParameter xmi:id="cls_Character_op_gainExperience_p1" name="amount" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_isAlive" name="isAlive" visibility="public">
          <type xmi:idref="umldt_Boolean"/>
          <body>Returns health > 0</body>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_takeDmg" name="takeDmg" visibility="public">
          <body>Reduces health with bounds check (min 0).</body>
          <ownedParameter xmi:id="cls_Character_op_takeDmg_p1" name="amount" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_heal" name="heal" visibility="public">
          <body>Restores health up to maxHealth.</body>
          <ownedParameter xmi:id="cls_Character_op_heal_p1" name="amount" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getName" name="getName" visibility="public">
          <type xmi:idref="umldt_String"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_setName" name="setName" visibility="public">
          <ownedParameter xmi:id="cls_Character_op_setName_p1" name="name" type="umldt:String"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getHealth" name="getHealth" visibility="public">
          <type xmi:idref="umldt_Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_setHealth" name="setHealth" visibility="public">
          <body>Sets health with bounds check: Math.max(0, Math.min(maxHealth, health))</body>
          <ownedParameter xmi:id="cls_Character_op_setHealth_p1" name="health" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getMaxHealth" name="getMaxHealth" visibility="public">
          <type xmi:idref="umldt_Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_setMaxHealth" name="setMaxHealth" visibility="public">
          <ownedParameter xmi:id="cls_Character_op_setMaxHealth_p1" name="maxHealth" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getLevel" name="getLevel" visibility="public">
          <type xmi:idref="umldt_Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_setLevel" name="setLevel" visibility="public">
          <ownedParameter xmi:id="cls_Character_op_setLevel_p1" name="level" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getExp" name="getExp" visibility="public">
          <type xmi:idref="umldt_Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_setExp" name="setExp" visibility="public">
          <ownedParameter xmi:id="cls_Character_op_setExp_p1" name="exp" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getInventory" name="getInventory" visibility="public">
          <type xmi:idref="cls_Inventory"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getQuestBook" name="getQuestBook" visibility="public">
          <type xmi:idref="cls_QuestBook"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Character_op_getStats" name="getStats" visibility="public">
          <type xmi:idref="umldt_String"/>
          <body>Returns formatted stats: "Name [Lv.X] HP: cur/max | EXP: cur/req"</body>
        </ownedOperation>
      </packagedElement>

      <!-- ====================================================== -->
      <!-- CLASS: Warrior                                          -->
      <!-- ====================================================== -->
      <packagedElement xmi:type="uml:Class" xmi:id="cls_Warrior" name="Warrior">
        <ownedComment xmi:id="cmt_Warrior">
          <body>High-HP melee fighter with critical strike ability.
Base HP: 150, Attack: 15 + (level * 3)
Special: 20% chance for Critical Strike (1.5x damage)</body>
        </ownedComment>

        <ownedOperation xmi:id="cls_Warrior_ctor1" name="Warrior" visibility="public">
          <body>Constructor chaining: super(name, 150)</body>
          <ownedParameter xmi:id="cls_Warrior_ctor1_p1" name="name" type="umldt:String"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Warrior_ctor2" name="Warrior" visibility="public">
          <body>Constructor with custom HP: super(name, maxHealth)</body>
          <ownedParameter xmi:id="cls_Warrior_ctor2_p1" name="name" type="umldt:String"/>
          <ownedParameter xmi:id="cls_Warrior_ctor2_p2" name="maxHealth" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Warrior_op_getBaseAttack" name="getBaseAttack" visibility="protected">
          <type xmi:idref="umldt_Integer"/>
          <body>Returns: 15 + (getLevel() * 3)</body>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Warrior_op_attack" name="attack" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Overrides Character.attack(). 20% chance for CRITICAL STRIKE (1.5x damage).</body>
        </ownedOperation>
      </packagedElement>

      <!-- ====================================================== -->
      <!-- CLASS: Archer                                           -->
      <!-- ====================================================== -->
      <packagedElement xmi:type="uml:Class" xmi:id="cls_Archer" name="Archer">
        <ownedComment xmi:id="cmt_Archer">
          <body>Balanced fighter with double shot ability.
Base HP: 100, Attack: 12 + (level * 2)
Special: 30% chance for Double Shot (+50% damage)</body>
        </ownedComment>

        <ownedOperation xmi:id="cls_Archer_ctor1" name="Archer" visibility="public">
          <body>Constructor chaining: super(name, 100)</body>
          <ownedParameter xmi:id="cls_Archer_ctor1_p1" name="name" type="umldt:String"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Archer_ctor2" name="Archer" visibility="public">
          <body>Constructor with custom HP: super(name, maxHealth)</body>
          <ownedParameter xmi:id="cls_Archer_ctor2_p1" name="name" type="umldt:String"/>
          <ownedParameter xmi:id="cls_Archer_ctor2_p2" name="maxHealth" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Archer_op_getBaseAttack" name="getBaseAttack" visibility="protected">
          <type xmi:idref="umldt_Integer"/>
          <body>Returns: 12 + (getLevel() * 2)</body>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Archer_op_attack" name="attack" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Overrides Character.attack(). 30% chance for DOUBLE SHOT (+50% damage).</body>
        </ownedOperation>
      </packagedElement>

      <!-- ====================================================== -->
      <!-- CLASS: Wizard                                           -->
      <!-- ====================================================== -->
      <packagedElement xmi:type="uml:Class" xmi:id="cls_Wizard" name="Wizard">
        <ownedComment xmi:id="cmt_Wizard">
          <body>Low-HP magic user with arcane blast ability.
Base HP: 80, Attack: 20 + (level * 4)
Special: 25% chance for Arcane Blast (2x damage)</body>
        </ownedComment>

        <ownedOperation xmi:id="cls_Wizard_ctor1" name="Wizard" visibility="public">
          <body>Constructor chaining: super(name, 80)</body>
          <ownedParameter xmi:id="cls_Wizard_ctor1_p1" name="name" type="umldt:String"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Wizard_ctor2" name="Wizard" visibility="public">
          <body>Constructor with custom HP: super(name, maxHealth)</body>
          <ownedParameter xmi:id="cls_Wizard_ctor2_p1" name="name" type="umldt:String"/>
          <ownedParameter xmi:id="cls_Wizard_ctor2_p2" name="maxHealth" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Wizard_op_getBaseAttack" name="getBaseAttack" visibility="protected">
          <type xmi:idref="umldt_Integer"/>
          <body>Returns: 20 + (getLevel() * 4)</body>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Wizard_op_attack" name="attack" visibility="public">
          <type xmi:idref="umldt_Integer"/>
          <body>Overrides Character.attack(). 25% chance for ARCANE BLAST (2x damage).</body>
        </ownedOperation>
      </packagedElement>

    </packagedElement>

    <!-- ======================================================== -->
    <!-- PACKAGE: enemy                                           -->
    <!-- ======================================================== -->
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_enemy" name="enemy">

      <!-- ABSTRACT CLASS: Enemy -->
      <packagedElement xmi:type="uml:Class" xmi:id="cls_Enemy" name="Enemy" isAbstract="true">
        <ownedComment xmi:id="cmt_Enemy">
          <body>Abstract base class for all hostile entities. Implements CombatMan.
Fields: name, health, maxHealth, baseAttack, expReward.
Attack formula: baseAttack + random(-2, +2).</body>
        </ownedComment>

        <ownedAttribute xmi:id="cls_Enemy_f_name" name="name" visibility="private"/>
        <ownedAttribute xmi:id="cls_Enemy_f_health" name="health" visibility="private"/>
        <ownedAttribute xmi:id="cls_Enemy_f_maxHealth" name="maxHealth" visibility="private"/>
        <ownedAttribute xmi:id="cls_Enemy_f_baseAttack" name="baseAttack" visibility="private"/>
        <ownedAttribute xmi:id="cls_Enemy_f_expReward" name="expReward" visibility="private"/>

        <ownedOperation xmi:id="cls_Enemy_ctor" name="Enemy" visibility="public">
          <ownedParameter xmi:id="cls_Enemy_ctor_p1" name="name" type="umldt:String"/>
          <ownedParameter xmi:id="cls_Enemy_ctor_p2" name="maxHealth" type="umldt:Integer"/>
          <ownedParameter xmi:id="cls_Enemy_ctor_p3" name="baseAttack" type="umldt:Integer"/>
          <ownedParameter xmi:id="cls_Enemy_ctor_p4" name="expReward" type="umldt:Integer"/>
        </ownedOperation>
        <ownedOperation xmi:id="cls_Enemy_op_attack" name="attack" visibility="public"/>
        <ownedOperation xmi:id="cls_Enemy_op_takeDmg" name="takeDmg" visibility="public"/>
        <ownedOperation xmi:id="cls_Enemy_op_isAlive" name="isAlive" visibility="public"/>
        <ownedOperation xmi:id="cls_Enemy_op_getName" name="getName" visibility="public"/>
        <ownedOperation xmi:id="cls_Enemy_op_getExpReward" name="getExpReward" visibility="public"/>
        <ownedOperation xmi:id="cls_Enemy_op_getDisplayInfo" name="getDisplayInfo" visibility="public"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Goblin" name="Goblin">
        <ownedComment><body>HP:40, ATK:8, EXP:25. Special: Dirty Punch (20%, +5 dmg)</body></ownedComment>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cls_Orc" name="Orc">
        <ownedComment><body>HP:80, ATK:14, EXP:50. Special: Axe Swing (15%, 1.8x dmg)</body></ownedComment>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cls_DragonBoss" name="DragonBoss">
        <ownedComment><body>HP:300, ATK:30, EXP:200. Enrage at 50% HP (+15 ATK). Fire Breath (30%, +20 dmg)</body></ownedComment>
        <ownedAttribute xmi:id="cls_DragonBoss_f_enraged" name="enraged" visibility="private"/>
      </packagedElement>

    </packagedElement>

    <!-- ======================================================== -->
    <!-- PACKAGE: item                                            -->
    <!-- ======================================================== -->
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_item" name="item">

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Item" name="Item" isAbstract="true">
        <ownedComment><body>Abstract base for all items. Fields: name, description, value.
Abstract methods: use(CombatMan), getType().</body></ownedComment>
        <ownedAttribute xmi:id="cls_Item_f_name" name="name" visibility="private"/>
        <ownedAttribute xmi:id="cls_Item_f_description" name="description" visibility="private"/>
        <ownedAttribute xmi:id="cls_Item_f_value" name="value" visibility="private"/>
        <ownedOperation xmi:id="cls_Item_op_use" name="use" visibility="public" isAbstract="true"/>
        <ownedOperation xmi:id="cls_Item_op_getType" name="getType" visibility="public" isAbstract="true"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Weapon" name="Weapon">
        <ownedComment><body>Equippable attack power boost. Adds attackPower to character damage.</body></ownedComment>
        <ownedAttribute xmi:id="cls_Weapon_f_attackPower" name="attackPower" visibility="private"/>
        <ownedOperation xmi:id="cls_Weapon_op_use" name="use" visibility="public"/>
        <ownedOperation xmi:id="cls_Weapon_op_getType" name="getType" visibility="public"/>
        <ownedOperation xmi:id="cls_Weapon_op_getAttackPower" name="getAttackPower" visibility="public"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Consumable" name="Consumable">
        <ownedComment><body>Usable health restoration item. Heals target by healAmount.</body></ownedComment>
        <ownedAttribute xmi:id="cls_Consumable_f_healAmount" name="healAmount" visibility="private"/>
        <ownedOperation xmi:id="cls_Consumable_op_use" name="use" visibility="public"/>
        <ownedOperation xmi:id="cls_Consumable_op_getType" name="getType" visibility="public"/>
        <ownedOperation xmi:id="cls_Consumable_op_getHealAmount" name="getHealAmount" visibility="public"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Inventory" name="Inventory">
        <ownedComment><body>Manages player item storage. Fixed-size array (max 10).
Tracks equipped weapon index.</body></ownedComment>
        <ownedAttribute xmi:id="cls_Inventory_f_MAX_SIZE" name="MAX_SIZE" visibility="private" isStatic="true"/>
        <ownedAttribute xmi:id="cls_Inventory_f_items" name="items" visibility="private"/>
        <ownedAttribute xmi:id="cls_Inventory_f_count" name="count" visibility="private"/>
        <ownedAttribute xmi:id="cls_Inventory_f_equippedWeaponIndex" name="equippedWeaponIndex" visibility="private"/>
        <ownedOperation xmi:id="cls_Inventory_op_addItem" name="addItem" visibility="public"/>
        <ownedOperation xmi:id="cls_Inventory_op_removeItem" name="removeItem" visibility="public"/>
        <ownedOperation xmi:id="cls_Inventory_op_equipWeapon" name="equipWeapon" visibility="public"/>
        <ownedOperation xmi:id="cls_Inventory_op_getEquippedWeapon" name="getEquippedWeapon" visibility="public"/>
        <ownedOperation xmi:id="cls_Inventory_op_displayInventory" name="displayInventory" visibility="public"/>
      </packagedElement>

    </packagedElement>

    <!-- ======================================================== -->
    <!-- PACKAGE: progression                                     -->
    <!-- ======================================================== -->
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_progression" name="progression">

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Quest" name="Quest">
        <ownedComment><body>Kill-based objective. Tracks targetEnemy, requiredKills, currentKills.</body></ownedComment>
        <ownedAttribute xmi:id="cls_Quest_f_name" name="name" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_description" name="description" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_targetEnemy" name="targetEnemy" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_requiredKills" name="requiredKills" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_currentKills" name="currentKills" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_reward" name="reward" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_completed" name="completed" visibility="private"/>
        <ownedAttribute xmi:id="cls_Quest_f_active" name="active" visibility="private"/>
        <ownedOperation xmi:id="cls_Quest_op_addKill" name="addKill" visibility="public"/>
        <ownedOperation xmi:id="cls_Quest_op_getProgress" name="getProgress" visibility="public"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_QuestBook" name="QuestBook">
        <ownedComment><body>Manages quest storage. Fixed-size array (max 5).
Auto-updates quests on enemy kill via notifyKill().</body></ownedComment>
        <ownedAttribute xmi:id="cls_QuestBook_f_MAX_QUESTS" name="MAX_QUESTS" visibility="private" isStatic="true"/>
        <ownedAttribute xmi:id="cls_QuestBook_f_quests" name="quests" visibility="private"/>
        <ownedAttribute xmi:id="cls_QuestBook_f_count" name="count" visibility="private"/>
        <ownedOperation xmi:id="cls_QuestBook_op_addQuest" name="addQuest" visibility="public"/>
        <ownedOperation xmi:id="cls_QuestBook_op_activateQuest" name="activateQuest" visibility="public"/>
        <ownedOperation xmi:id="cls_QuestBook_op_notifyKill" name="notifyKill" visibility="public"/>
        <ownedOperation xmi:id="cls_QuestBook_op_displayQuests" name="displayQuests" visibility="public"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Reward" name="Reward">
        <ownedComment><body>Quest completion rewards: EXP, gold, and optional item name.</body></ownedComment>
        <ownedAttribute xmi:id="cls_Reward_f_exp" name="exp" visibility="private"/>
        <ownedAttribute xmi:id="cls_Reward_f_gold" name="gold" visibility="private"/>
        <ownedAttribute xmi:id="cls_Reward_f_itemName" name="itemName" visibility="private"/>
        <ownedOperation xmi:id="cls_Reward_op_getExp" name="getExp" visibility="public"/>
        <ownedOperation xmi:id="cls_Reward_op_getGold" name="getGold" visibility="public"/>
        <ownedOperation xmi:id="cls_Reward_op_getItemName" name="getItemName" visibility="public"/>
      </packagedElement>

    </packagedElement>

    <!-- ======================================================== -->
    <!-- PACKAGE: root                                            -->
    <!-- ======================================================== -->
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_root" name="root">

      <packagedElement xmi:type="uml:Class" xmi:id="cls_Battle" name="Battle">
        <ownedComment><body>Manages turn-based combat between Character and Enemy.
Battle loop, attack, item use, flee, status.</body></ownedComment>
        <ownedAttribute xmi:id="cls_Battle_f_player" name="player" visibility="private"/>
        <ownedAttribute xmi:id="cls_Battle_f_enemy" name="enemy" visibility="private"/>
        <ownedAttribute xmi:id="cls_Battle_f_scanner" name="scanner" visibility="private"/>
        <ownedAttribute xmi:id="cls_Battle_f_fled" name="fled" visibility="private"/>
        <ownedOperation xmi:id="cls_Battle_op_start" name="start" visibility="public"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="cls_GameEngine" name="GameEngine">
        <ownedComment><body>Main entry point. Character creation, main menu, shop, exploration.</body></ownedComment>
        <ownedAttribute xmi:id="cls_GameEngine_f_scanner" name="scanner" visibility="private"/>
        <ownedAttribute xmi:id="cls_GameEngine_f_player" name="player" visibility="private"/>
        <ownedAttribute xmi:id="cls_GameEngine_f_running" name="running" visibility="private"/>
        <ownedAttribute xmi:id="cls_GameEngine_f_gold" name="gold" visibility="private"/>
