@startuml KingdomQuest_ClassDiagram
' ============================================
' Kingdom Quest - Full Class Diagram
' Object-Oriented Programming Section 1
' ============================================

skinparam classAttributeIconSize 0
skinparam classFontSize 14
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam shadowing false
skinparam monochrome true

skinparam class {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
    HeaderBackgroundColor #F0F0F0
}

skinparam interface {
    BackgroundColor #E8F4FD
    BorderColor Black
}

skinparam abstract {
    BackgroundColor #FFF8E1
    BorderColor Black
}

' ============================================
' INTERFACES
' ============================================
interface CombatMan <<interface>> {
    +attack() : int
    +takeDmg(int dmg) : void
    +isAlive() : boolean
    +getName() : String
    +getHealth() : int
    +getMaxHealth() : int
}

' ============================================
' ABSTRACT CLASSES
' ============================================
abstract class Character <<abstract>> {
    - name : String
    - health : int
    - maxHealth : int
    - level : int
    - exp : int
    - inventory : Inventory
    - questBook : QuestBook
    --
    + Character(String name)
    + Character(String name, int maxHealth)
    + attack() : int
    # getBaseAttack() : int {abstract}
    + gainExperience(int amount) : void
    + isAlive() : boolean
    + takeDmg(int amount) : void
    + heal(int amount) : void
    + getName() : String
    + setName(String name) : void
    + getHealth() : int
    + setHealth(int health) : void
    + getMaxHealth() : int
    + setMaxHealth(int maxHealth) : void
    + getLevel() : int
    + setLevel(int level) : void
    + getExp() : int
    + setExp(int exp) : void
    + getInventory() : Inventory
    + getQuestBook() : QuestBook
    + getStats() : String
}

abstract class Enemy <<abstract>> {
    - name : String
    - health : int
    - maxHealth : int
    - baseAttack : int
    - expReward : int
    --
    + Enemy(String name, int maxHealth, int baseAttack, int expReward)
    + attack() : int
    + takeDmg(int dmg) : void
    + isAlive() : boolean
    + getName() : String
    + setName(String name) : void
    + getHealth() : int
    + setHealth(int health) : void
    + getMaxHealth() : int
    + getBaseAttack() : int
    + setBaseAttack(int baseAttack) : void
    + getExpReward() : int
    + setExpReward(int expReward) : void
    + getDisplayInfo() : String
}

abstract class Item <<abstract>> {
    - name : String
    - description : String
    - value : int
    --
    + Item(String name, String description)
    + Item(String name, String description, int value)
    + use(CombatMan target) : String {abstract}
    + getType() : String {abstract}
    + getName() : String
    + setName(String name) : void
    + getDescription() : String
    + setDescription(String description) : void
    + getValue() : int
    + setValue(int value) : void
    + toString() : String
}

' ============================================
' CHARACTER SUBCLASSES
' ============================================
class Warrior {
    + Warrior(String name)
    + Warrior(String name, int maxHealth)
    # getBaseAttack() : int
    + attack() : int
    ..
    Base HP: 150
    ATK: 15 + level * 3
    Special: Critical Strike (20%, 1.5x)
}

class Archer {
    + Archer(String name)
    + Archer(String name, int maxHealth)
    # getBaseAttack() : int
    + attack() : int
    ..
    Base HP: 100
    ATK: 12 + level * 2
    Special: Double Shot (30%, +50%)
}

class Wizard {
    + Wizard(String name)
    + Wizard(String name, int maxHealth)
    # getBaseAttack() : int
    + attack() : int
    ..
    Base HP: 80
    ATK: 20 + level * 4
    Special: Arcane Blast (25%, 2x)
}

' ============================================
' ENEMY SUBCLASSES
' ============================================
class Goblin {
    + Goblin()
    + Goblin(String name)
    + attack() : int
    ..
    HP: 40
    ATK: 8
    EXP: 25
    Special: Dirty Punch (20%, +5)
}

class Orc {
    + Orc()
    + Orc(String name)
    + attack() : int
    ..
    HP: 80
    ATK: 14
    EXP: 50
    Special: Axe Swing (15%, 1.8x)
}

class DragonBoss {
    - enraged : boolean
    + DragonBoss()
    + DragonBoss(String name)
    + attack() : int
    + isEnraged() : boolean
    ..
    HP: 300
    ATK: 30 (45 enraged)
    EXP: 200
    Enrage at 50% HP
    Special: Fire Breath (30%, +20)
}

' ============================================
' ITEM SUBCLASSES
' ============================================
class Weapon {
    - attackPower : int
    + Weapon(String name, String description, int attackPower)
    + Weapon(String name, int attackPower)
    + use(CombatMan target) : String
    + getType() : String
    + getAttackPower() : int
    + setAttackPower(int attackPower) : void
    ..
    Equips to character
    Adds ATK to damage
}

class Consumable {
    - healAmount : int
    + Consumable(String name, String description, int healAmount)
    + Consumable(String name, int healAmount)
    + use(CombatMan target) : String
    + getType() : String
    + getHealAmount() : int
    + setHealAmount(int healAmount) : void
    ..
    Heals target Character
    Consumed on use
}

' ============================================
' INVENTORY
' ============================================
class Inventory {
    - MAX_SIZE : int = 10
    - items : Item[]
    - count : int
    - equippedWeaponIndex : int
    --
    + Inventory()
    + addItem(Item item) : boolean
    + removeItem(int index) : Item
    + getItem(int index) : Item
    + equipWeapon(int index) : boolean
    + getEquippedWeapon() : Weapon
    + getAllItems() : Item[]
    + getCount() : int
    + getMaxSize() : int
    + displayInventory() : void
    ..
    Fixed-size array (max 10)
    Tracks equipped weapon
}

' ============================================
' PROGRESSION
' ============================================
class Quest {
    - name : String
    - description : String
    - targetEnemy : String
    - requiredKills : int
    - currentKills : int
    - reward : Reward
    - completed : boolean
    - active : boolean
    --
    + Quest(String name, String description, String targetEnemy, int requiredKills, Reward reward)
    + addKill(String enemyName) : void
    + getName() : String
    + setName(String name) : void
    + getDescription() : String
    + getTargetEnemy() : String
    + getRequiredKills() : int
    + getCurrentKills() : int
    + getReward() : Reward
    + isCompleted() : boolean
    + isActive() : boolean
    + setActive(boolean active) : void
    + getProgress() : String
    ..
    Kill-based objective
    Tracks progress
}

class QuestBook {
    - MAX_QUESTS : int = 5
    - quests : Quest[]
    - count : int
    --
    + QuestBook()
    + addQuest(Quest quest) : boolean
    + activateQuest(int index) : void
    + getQuest(int index) : Quest
    + getActiveQuests() : Quest[]
    + notifyKill(String enemyName) : void
    + getCount() : int
    + displayQuests() : void
    + toString() : String
    ..
    Fixed-size array (max 5)
    Auto-updates on kill
}

class Reward {
    - exp : int
    - gold : int
    - itemName : String
    --
    + Reward(int exp, int gold)
    + Reward(int exp, int gold, String itemName)
    + getExp() : int
    + setExp(int exp) : void
    + getGold() : int
    + setGold(int gold) : void
    + getItemName() : String
    + setItemName(String itemName) : void
    + getDescription() : String
    ..
    EXP + Gold + Item
}

' ============================================
' BATTLE & GAME ENGINE
' ============================================
class Battle {
    - player : Character
    - enemy : Enemy
    - scanner : Scanner
    - fled : boolean
    --
    + Battle(Character player, Enemy enemy, Scanner scanner)
    + start() : boolean
    - playerTurnAttack() : void
    - playerTurnItem() : void
    - attemptFlee() : boolean
    - enemyTurn() : void
    - readInt() : int
    ..
    Turn-based combat loop
    Returns true on victory
}

class GameEngine {
    - scanner : Scanner
    - player : Character
    - running : boolean
    - gold : int
    - questsCompleted : int
    --
    + GameEngine()
    + start() : void
    - printBanner() : void
    - createCharacter() : void
    - initializeStarterItems() : void
    - initializeQuests() : void
    - displayMainMenu() : void
    - handleMainMenu(int choice) : void
    - exploreArea() : void
    - generateRandomEnemy() : Enemy
    - checkQuestRewards() : void
    - displayStatus() : void
    - openInventory() : void
    - viewQuests() : void
    - openShop() : void
    - restAtInn() : void
    - readIntInput() : int
    + main(String[] args) : void
    ..
    Main entry point
    7-option menu loop
}

' ============================================
' RELATIONSHIPS
' ============================================

' Interface Implementation
Character ..|> CombatMan : implements
Enemy ..|> CombatMan : implements

' Inheritance
Warrior --|> Character : extends
Archer --|> Character : extends
Wizard --|> Character : extends

Goblin --|> Enemy : extends
Orc --|> Enemy : extends
DragonBoss --|> Enemy : extends

Weapon --|> Item : extends
Consumable --|> Item : extends

' Composition (HAS-A)
Character *-- Inventory : owns
Character *-- QuestBook : owns
Quest *-- Reward : has

' Aggregation (contains)
Inventory o-- Item : contains
QuestBook o-- Quest : contains

' Associations
Battle o-- Character : uses
Battle o-- Enemy : uses
GameEngine o-- Character : runs
GameEngine o-- Battle : creates

@enduml
